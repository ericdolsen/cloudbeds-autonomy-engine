# ==========================================
# CLOUDBEDS AUTONOMY ENGINE ENVIRONMENT
# ==========================================

# 1. AI ROUTING — three lanes, three models, one job each.
#    text   → high-volume guest text + tool calling      (Gemini 2.5 Flash)
#    vision → zero-mistake Cloudbeds UI screen-clicking  (Claude Sonnet 4.5)
#    voice  → real-time phone-line audio                 (Gemini 3.1 Live)
GEMINI_API_KEY=YOUR_GEMINI_KEY
ANTHROPIC_API_KEY=YOUR_ANTHROPIC_KEY

TEXT_MODEL="gemini-2.5-flash"
VISION_MODEL="claude-sonnet-4-5"
VOICE_MODEL="gemini-3.1-live"

# Legacy single-model knob — still honored as a fallback for TEXT_MODEL.
GEMINI_MODEL="gemini-2.5-flash"

# 2. CLOUDBEDS API CREDENTIALS
CLOUDBEDS_PROPERTY_ID=10074733072513
CLOUDBEDS_HOST=https://hotels.cloudbeds.com/api/v1.3
CLOUDBEDS_API_KEY=MOCK_KEY

# 2a. NIGHT AUDIT REPORT — overrides for fields Cloudbeds returns inconsistently.
#     Set these if BoB occupancy looks > 100% or the forecast shows $0 revenue.
#
# Physical room count. Without this, the engine tries to derive it from
# /getRooms and can land on a per-room-type subset (e.g. 20 instead of 50).
# Authoritative override — set it to your real physical count.
TOTAL_ROOMS=50
#
# Field name on /getReservations that holds net per-night room revenue.
# Leave unset by default; the code tries dailyRates → roomTotal → subtotal-tax
# → total in order. If your property uses a non-standard field, hit
# GET /api/employee/debug/report-shape to inspect a sample reservation, then
# set this to the field name (e.g. FORECAST_REVENUE_FIELD=roomCharge).
#
# Common opt-in: `balance`. For OTA bookings (Booking.com, Expedia Collect)
# `balance` equals room+tax until checkout — a usable revenue proxy when
# Cloudbeds returns a "lite" reservation with no rate fields. Note that
# balance drops to 0 once a guest pays, so it understates revenue for
# direct-prepay bookings. Use only if the diagnostic dump shows no other
# usable field.
# FORECAST_REVENUE_FIELD=balance

# 3. WHISTLE GUEST SMS INTEGRATION
WHISTLE_API_KEY=

# 4. REPORTING & HOUSEKEEPING DATABASES (Google Sheets API)
GOOGLE_SHEET_ID=
GOOGLE_SERVICE_ACCOUNT_EMAIL=
GOOGLE_PRIVATE_KEY=

# 5. NODEMAILER (AUTOMATED GMAIL REPORTER & INVOICER)
SMTP_USER=
SMTP_PASS=
REPORT_EMAILS=management@gatewayparkhotel.com
